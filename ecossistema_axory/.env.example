# Supabase Auth (mantido)
# Obtenha em: https://supabase.com/dashboard -> seu projeto -> Settings -> API
# - Project URL -> NEXT_PUBLIC_SUPABASE_URL
# - Project API keys -> anon (public) -> NEXT_PUBLIC_SUPABASE_ANON_KEY

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SEU_ANON_KEY_AQUI

# PostgREST (substitui Supabase DB/API)
# As chamadas usam o mesmo Bearer token emitido pelo Supabase Auth.

NEXT_PUBLIC_POSTGREST_URL=https://rest-axdeal.axory.com.br

# MinIO (substitui Supabase Storage)
# URL publica usada para montar os links dos arquivos.

NEXT_PUBLIC_STORAGE_PUBLIC_URL=https://storage.axory.com.br

# Credenciais server-side para upload/remocao via rota Next.js usando @aws-sdk/client-s3.
# Nao use prefixo NEXT_PUBLIC_ nessas credenciais.

MINIO_ENDPOINT=https://storage.axory.com.br
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY_ID=SEU_ACCESS_KEY
MINIO_SECRET_ACCESS_KEY=SEU_SECRET_KEY
